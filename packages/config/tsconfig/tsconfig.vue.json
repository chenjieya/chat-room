{
  // Vue 3 + Vite 前端专用配置，继承基础配置
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // 前端运行环境与模块解析（由打包器处理）
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    // Vue + Vite 相关类型
    "types": ["vite/client"],

    // 前端通常不需要生成声明文件
    "declaration": false
  }
}
