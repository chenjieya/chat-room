{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "lib": ["ESNext"],
    "declaration": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "rootDir": "./src", // 必须正确指向源码目录
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "importHelpers": true,
    "noEmitHelpers": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"], // 只包含 src 目录
  "exclude": ["node_modules", "dist"]
}
