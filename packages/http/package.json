{
  "name": "@alvis/http",
  "version": "1.0.0",
  "description": "对于axios的二次封装",
  "keywords": [
    "axios",
    "http"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "author": "jie.chen",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "main": "dist/alvis-http.cjs.js",
    "module": "dist/alvis-http.esm.js",
    "types": "dist/types/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/alvis-http.esm.js",
        "require": "./dist/alvis-http.cjs.js",
        "types": "./dist/types/index.d.ts"
      }
    }
  },
  "peerDependencies": {
    "axios": ">=1.0.0"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "axios": "^1.13.6",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
